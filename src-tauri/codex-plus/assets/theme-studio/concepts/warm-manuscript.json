    "sidebar": ".cc-theme-shell-sidebar",
    "projectRow": ".cc-theme-shell-project-row",
    "threadRow": ".cc-theme-shell-thread-row",
    "composer": ".cc-theme-shell-composer",
    "quickCards": ".cc-theme-showcase-card",
    "protectedSurfaces": [
      "[role=\"menu\"]",
      "[role=\"listbox\"]",
      "[role=\"dialog\"]",
      "[role=\"alertdialog\"]",
      "[data-slot=\"popover-content\"]",
      "[data-slot=\"command\"]"
    ],
    "untouchedSurface": "[role=\"dialog\"][aria-label=\"图片预览\"], [role=\"dialog\"][aria-label=\"Image preview\"]"
  },
  "acceptanceContract": {
    "scope": [
      "每个样式选择器必须限定在 warm-manuscript 主题根节点下",
      "不得使用裸 aside、nav、main、body 或 class 通配选择器覆盖 Codex",
      "设置导航不得被识别或绘制成主题侧栏"
    ],
    "interaction": [
      "四张快捷卡继续使用原生 button 和原有点击事件",
      "快捷卡只填充原生 composer，不创建第二个输入框",
      "项目行和任务行不产生独立水平或垂直滚动条",
      "鼠标位于项目或任务行时仍由运行时把滚轮传递给主侧栏滚动容器"
    ],
    "operationalSurfaces": [
      "菜单、列表框、Popover、命令面板和普通对话框保持不透明",
      "设置页输入、下拉框、开关和二级确认弹窗保持可读",
      "图片预览继续由共享预览规则控制，主题切片不得修改其定位、保存按钮或关闭按钮",
      "代码块、Diff、终端和 Monaco 在任务页保持不透明"
    ],
    "responsive": [
      "宽视口为单排四卡",
      "宽度不高于 1080px 时改为稳定 2×2",
      "宽度不高于 720px 时仍保持 2×2，隐藏非关键 companion、状态和金币装饰",
      "标题、卡片和 composer 不发生水平溢出或相互覆盖"
    ],
    "visual": [
      "左侧内容安全区保持低信息宣纸纹理",
      "人物、双手、笔记本和关键道具保持在右侧裁切安全区",
      "红、金、玉绿形成清晰层级，正文始终使用深棕墨色",
      "窗口控制符号在浅色外观下使用黑色"
    ]
  }
